---
title: Data Pipeline — Ingestion to Warehouse
---
flowchart TD
    subgraph Ingestion["🔽 Ingestion Layer"]
        SRC_API[/"API Stream"/]
        SRC_S3[("S3 Bucket")]
        SRC_KAFKA[/"Kafka Topic"/]
        COLLECT["Collector Service"]

        SRC_API --> COLLECT
        SRC_S3 --> COLLECT
        SRC_KAFKA --> COLLECT
    end

    subgraph Processing["⚙️ Processing Layer"]
        SCHEMA{"Schema Valid?"}
        PARSE["Parse & Normalize"]
        DEDUP["Deduplicate Records"]
        ENRICH["Enrich with Metadata"]
        TRANSFORM["Apply Business Rules"]
        QC{"Quality Check Passed?"}
    end

    subgraph Loading["📦 Loading Layer"]
        STAGE[("Staging Table")]
        MERGE["Upsert / Merge"]
        DW[("Data Warehouse")]
        NOTIFY["Send Notification"]
        CATALOG["Update Data Catalog"]
    end

    subgraph ErrorHandling["🚨 Error Handling"]
        DLQ[("Dead Letter Queue")]
        ALERT_INVALID["Alert: Invalid Schema"]
        RETRY{"Retry Count < 3?"}
        REPROCESS["Reprocess Record"]
        ALERT_FAIL["Alert: QC Failure"]
        QUARANTINE[("Quarantine Store")]
    end

    COLLECT --> SCHEMA

    SCHEMA -->|Yes| PARSE
    SCHEMA -->|No| DLQ
    DLQ --> ALERT_INVALID

    PARSE --> DEDUP
    DEDUP --> ENRICH
    ENRICH --> TRANSFORM
    TRANSFORM --> QC

    QC -->|Pass| STAGE
    QC -->|Fail| RETRY

    RETRY -->|Yes| REPROCESS
    RETRY -->|No| QUARANTINE
    QUARANTINE --> ALERT_FAIL
    REPROCESS --> TRANSFORM

    STAGE --> MERGE
    MERGE --> DW
    DW --> NOTIFY
    DW --> CATALOG

    classDef source fill:#e1f5fe,stroke:#0288d1,color:#01579b
    classDef process fill:#f3e5f5,stroke:#7b1fa2,color:#4a148c
    classDef decision fill:#fff3e0,stroke:#ef6c00,color:#e65100
    classDef storage fill:#e8f5e9,stroke:#388e3c,color:#1b5e20
    classDef error fill:#ffebee,stroke:#c62828,color:#b71c1c
    classDef notify fill:#fffde7,stroke:#f9a825,color:#f57f17

    class SRC_API,SRC_S3,SRC_KAFKA source
    class COLLECT,PARSE,DEDUP,ENRICH,TRANSFORM process
    class SCHEMA,QC,RETRY decision
    class STAGE,DW,DLQ,QUARANTINE storage
    class DLQ,ALERT_INVALID,ALERT_FAIL,REPROCESS error
    class NOTIFY,CATALOG notify
    class MERGE process
